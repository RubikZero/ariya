{
  "name": "ariya",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "deploy": "npm run db:migrate && wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "vitest",
    "cf-typegen": "wrangler types",
    "build:strings": "node scripts/generate-strings.mjs",
    "build:frontend": "cd frontend && npm run build",
    "setup": "node scripts/setup.mjs",
    "gen-key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "predeploy": "npm run build:strings && npm run build:frontend",
    "predev": "npm run build:strings",
    "pretest": "npm run build:strings"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@types/node": "^25.9.2",
    "typescript": "^5.5.2",
    "vitest": "~3.2.0",
    "wrangler": "^4.99.0"
  }
}