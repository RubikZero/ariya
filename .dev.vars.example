# HMAC-SHA256 密钥，用于验证 Mod 端发来的请求
# 生产环境请通过 `npx wrangler secret put HMAC_SECRET_KEY` 设置
HMAC_SECRET_KEY=your-secret-key-here

# 请求过期时间（秒），超过此时间的请求将被拒绝
TIMEOUT=600

# 管理面板访问令牌（可选，推荐使用 Cloudflare API Token）
# 不设置则管理面板不可用
# 生产环境请通过 `npx wrangler secret put ADMIN_KEY` 设置
ADMIN_KEY=your-cloudflare-api-token-or-any-secret

# Cloudflare Zero Trust 团队域名（用于 JWT 验证和组名提取）
# 格式为 xxx.cloudflareaccess.com，在 Zero Trust Dashboard → Settings → Team domain 中查看
# 设置后 Worker 会解析 Access JWT 中的 email 和 groups 字段，
# 根据组名自动注册用户（组名包含 admin 则角色为管理员，否则为成员）
# 生产环境请通过 `npx wrangler secret put CF_ACCESS_TEAM_DOMAIN` 设置
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com

# 管理员邮箱（可选）
# 通过 Cloudflare Access 登录时，若邮箱匹配此值，自动获得 admin 权限
# 不设置时所有首次 Access 用户默认 role=member
# 生产环境请通过 `npx wrangler secret put OWNER_EMAIL` 设置
# OWNER_EMAIL=admin@example.com