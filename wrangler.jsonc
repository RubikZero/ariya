{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ariya",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-10",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ariya-sts2-mod-logs",
			"database_id": "placeholder"
		}
	]
}